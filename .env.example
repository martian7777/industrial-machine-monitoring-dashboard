# ============================================================================
#  Industrial Machine Monitoring — Environment Configuration
#  Copy this file to ".env" and fill in your values.
# ============================================================================

# ---------------------------------------------------------------------------
#  DATABASE (Cloud Supabase)
# ---------------------------------------------------------------------------
# Get this from: Supabase Dashboard -> Project Settings -> Database -> Connection string
#
# Use the "Session pooler" (port 5432) or "Transaction pooler" (port 6543) URI.
# IMPORTANT: SQLAlchemy needs the "postgresql+psycopg2://" driver prefix.
#
# Example (Session pooler, IPv4-friendly):
#   DATABASE_URL=postgresql+psycopg2://postgres.abcdefghijklmno:YOUR-PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
#
# Example (Direct connection):
#   DATABASE_URL=postgresql+psycopg2://postgres:YOUR-PASSWORD@db.abcdefghijklmno.supabase.co:5432/postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/monitoring

# If your Supabase password / URL contains special characters, URL-encode them.
# Require SSL for cloud Supabase (set to "require" for cloud, "disable" for local docker).
DB_SSLMODE=require

# Optional Supabase API access (only needed if you later use the Supabase JS/Py client)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
#  BACKEND (FastAPI)
# ---------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated list of allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Auto-create tables + seed machines on startup (handy for a fresh cloud DB)
AUTO_INIT_DB=true

# ---------------------------------------------------------------------------
#  SIMULATOR
# ---------------------------------------------------------------------------
# Where the simulator POSTs telemetry. Inside docker use the service name.
BACKEND_URL=http://backend:8000
# Seconds between simulation ticks (per machine)
SIM_INTERVAL_SECONDS=2
# Probability (0-1) per tick of injecting a fault into a machine
SIM_FAULT_PROBABILITY=0.02

# ---------------------------------------------------------------------------
#  ETL WORKER
# ---------------------------------------------------------------------------
# How often the ETL aggregation runs (seconds). 3600 = hourly.
ETL_INTERVAL_SECONDS=3600

# ---------------------------------------------------------------------------
#  FRONTEND (Vite)  — must be prefixed with VITE_ to be exposed to the client
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/live
